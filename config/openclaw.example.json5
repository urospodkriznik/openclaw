// Example OpenClaw gateway + agent defaults (JSON5).
// Copy relevant sections into $OPENCLAW_CONFIG_DIR/openclaw.json
// or run ./scripts/bootstrap-config.sh to generate a minimal strict-JSON version.
{
  gateway: {
    mode: "local",
    bind: "lan", // Docker publishes 18789 on the host; see docs/SECURITY.md before exposing WAN
  },
  // Parse /command from message text (needed for reliable Telegram handling); see docs/TROUBLESHOOTING.md
  commands: {
    text: true,
    native: "auto",
    nativeSkills: "auto",
  },
  // Single-user Telegram DMs: one shared session; see https://docs.openclaw.ai/concepts/session
  session: {
    dmScope: "main",
  },
  // Longer provider guard helps Telegram + gog tool runs on small VMs (override via GEMINI_PROVIDER_TIMEOUT_SECONDS in .env)
  models: {
    providers: {
      google: { timeoutSeconds: 180 },
    },
  },
  agents: {
    defaults: {
      model: {
        // Gemini (google): verify model id with `docker compose run -T --rm openclaw-cli models list --provider google`
        primary: "google/gemini-3-flash-preview",
      },
      // Only inject startup prelude on explicit /reset-style turns, not on every "new" classification
      startupContext: {
        enabled: true,
        applyOn: ["reset"],
      },
    },
  },
  // tools.exec is mirrored by ./scripts/bootstrap-config.sh from SAFE_MODE / FULL_AUTONOMY / DEMO_MODE
  tools: {
    exec: {
      host: "gateway",
      security: "allowlist",
      ask: "on-miss",
    },
  },
}
