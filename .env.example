# Copy to .env and adjust. Never commit .env.
# See docs/DEPLOYMENT.md and docs/GCP_SETUP.md.
#
# --- Local Mac / Linux (Docker on your machine, no Secret Manager) ---
# - Keep USE_GSM_SECRETS=false; put secrets in this file (never commit .env).
# - Skip ./scripts/fetch-secrets-gsm.sh (it is a no-op when GSM is off).
#
# --- Which keys / secrets do I actually need? ---
# | Variable              | Required? | Purpose |
# |-----------------------|-----------|---------|
# | LLM_PROVIDER          | No        | `google` (default) or `openai` — bootstrap sets `agents.defaults.model.primary` in openclaw.json. |
# | GEMINI_API_KEY        | Yes*      | When LLM_PROVIDER=google: Google AI Studio key + GEMINI_MODEL. |
# | OPENAI_API_KEY        | Yes**     | When LLM_PROVIDER=openai: OpenAI API key + OPENAI_MODEL. |
# | TELEGRAM_BOT_TOKEN    | Yes***    | Telegram channel; from @BotFather. |
# | gog “API key” in .env | No        | gog uses OAuth / tokens stored under OPENCLAW_GOGCLI_CONFIG_DIR after `gog auth` on the host + `make sync-gog-config`. Optional: GOG_KEYRING_BACKEND=file + GOG_KEYRING_PASSWORD if your gog keyring is file-based. |
# * Vertex-only setups use ADC instead; this template defaults to developer API + GEMINI_API_KEY.
# ** When LLM_PROVIDER=openai and USE_GSM_SECRETS=false.
# *** Or USE_GSM_SECRETS=true and GSM for Telegram on servers; local = token in .env.
# - GOOGLE_CLOUD_PROJECT / GOOGLE_CLOUD_LOCATION: still set them — validate-env requires them;
#   use the same GCP project as Google AI Studio / OAuth for Workspace APIs (Calendar, Drive, …)
#   even when nothing runs on Compute Engine.
# - gog in Docker: containers are **Linux**. Do not `cp $(which gog)` from macOS — that is Mach-O.
#   Run `./scripts/install-gog-linux-for-docker.sh` (or `make install-gog-linux`) to place a Linux ELF
#   binary in `.openclaw-host-bin/gog`. Use `GOG_LINUX_ARCH=arm64` if your image is linux/arm64.
#   `./scripts/docker-compose.sh` only bind-mounts gog when the file is Linux ELF.
# - After host `gog auth`: run `make sync-gog-config` so OPENCLAW_GOGCLI_CONFIG_DIR is UID 1000-readable.
# - New clone (local Mac/Linux): `make init` — see README § Quick start.
# - New GCP VM: `make init-vm` (production compose + optional GSM; Linux only).
# - After changes: `make restart-dev` (local) or `make restart` (VM).

# Optional: agent / LLM idle timeouts — NOT written by bootstrap (some images reject unknown keys).
# Merge fragments manually into openclaw.json after verifying your OPENCLAW_IMAGE; see config/openclaw-timeouts.example.json5.

# --- OpenClaw image (prebuilt; do not build on e2-micro) ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Persisted OpenClaw home (config, auth profiles) and agent workspace (host paths)
OPENCLAW_CONFIG_DIR=./.openclaw-config
OPENCLAW_WORKSPACE_DIR=./workspace
# Skills such as imap-smtp-email read /home/node/.config/imap-smtp-email/.env — host dir is bind-mounted (gitignored).
OPENCLAW_IMAP_SMTP_CONFIG_DIR=./.openclaw-imap-smtp
# Optional: gog / Google Workspace CLI ([gogcli](https://github.com/openclaw/gogcli))
# Bind-mount requires a **Linux ELF** gog on the host (see install-gog-linux-for-docker.sh). OPENCLAW_GOG_HOST_PATH
# must also point at a Linux binary, not macOS Homebrew Mach-O.
# Override if your gog lives elsewhere:
# OPENCLAW_GOG_HOST_PATH=/path/to/gog
# Host staging dir for gogcli OAuth files (default ./.openclaw-gog-config). make sync-gog-config copies here;
# make push-gog-gateway (or restart-dev/local/dev) streams into the named Docker volume at /home/node/.config/gogcli.
# Do NOT point at ~/.config/gogcli as the staging dir unless you fix ACLs for sync; use sync-gog-cli-config.sh.
# macOS Homebrew gogcli often stores data in ~/Library/Application Support/gogcli — sync script copies from there automatically.
# Override if your gogcli data lives elsewhere:
# GOGCLI_SOURCE_DIR=/path/to/gogcli-data
# OPENCLAW_GOGCLI_CONFIG_DIR=./.openclaw-gog-config
# File keyring (must match what you use for "gog auth" on the host when GOG_KEYRING_BACKEND=file in .env):
# GOG_KEYRING_BACKEND=file
# GOG_KEYRING_PASSWORD=
# On macOS, run auth with the same vars loaded, e.g. from repo root:  set -a && source .env && set +a && gog auth add …
# Otherwise gog may store tokens in the login keychain; sync copies an empty keyring and Docker shows "No tokens stored".
# Optional default account for gog subcommands:
# GOG_ACCOUNT=you@gmail.com

# Gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=UTC

# Optional: generated on first bootstrap if empty
# OPENCLAW_GATEWAY_TOKEN=$(openssl rand -hex 24)

# Optional: raise on hosts with more RAM (e2-micro default in compose is 768m)
# OPENCLAW_MEMORY_LIMIT=1536m

# Runtime secret strategy
# - Local dev: keep USE_GSM_SECRETS=false and set local tokens in .env
# - GCP prod: set USE_GSM_SECRETS=true and fetch runtime secrets via Secret Manager + IAM
USE_GSM_SECRETS=false
GSM_PROJECT_ID=
GSM_TELEGRAM_BOT_TOKEN_SECRET=openclaw-telegram-bot-token
GSM_OPENAI_API_KEY_SECRET=openclaw-openai-api-key
# Optional: Gemini developer API (provider google); uncomment when the GSM secret exists
# GSM_GEMINI_API_KEY_SECRET=openclaw-gemini-api-key

# --- GCP project (Secret Manager, optional Vertex, metadata) ---
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=

# --- LLM (./scripts/bootstrap-config.sh → agents.defaults.model.primary; existing openclaw.json is merged, not replaced) ---
LLM_PROVIDER=google
# OPENAI_MODEL=gpt-5.4-nano

# --- Gemini developer API (when LLM_PROVIDER=google or unset) ---
# Create an API key in Google AI Studio (treat it like a secret — same role as an “API key” / “secret key”).
# Local: set GEMINI_API_KEY below. GCP + GSM: GSM_GEMINI_API_KEY_SECRET + fetch-secrets-gsm.sh writes .env.generated.
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Optional: merge timeout / idle keys into openclaw.json by hand (bootstrap does NOT write them — see config/openclaw-timeouts.example.json5).
GEMINI_API_KEY=

# --- Optional: Vertex AI (google-vertex + ADC) if your OpenClaw image loads that plugin ---
# VERTEX_MODEL=gemini-2.0-flash-001
# For Vertex-only setups, set agents.defaults.model.primary to google-vertex/<VERTEX_MODEL> manually.

# --- Telegram (configure channel; token often injected by CI on deploy) ---
TELEGRAM_BOT_TOKEN=

# --- OpenAI (when LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...

# --- Autonomy (see README) ---
SAFE_MODE=true
FULL_AUTONOMY=false
I_ACCEPT_FULL_AUTONOMY_RISK=
# Headless (Telegram only, no Control UI on 18789): SAFE_MODE exec approvals time out or show
# "Command approval unavailable". Set BOTH below, then ./scripts/bootstrap-config.sh + make restart-dev.
# Read docs/SECURITY.md — widens gateway tools.exec only on a machine you trust.
TRUSTED_HEADLESS_EXEC=true
I_ACCEPT_HEADLESS_EXEC_RISK=1
DEMO_MODE=false

# --- Optional: enable Gmail Pub/Sub hooks (advanced; off by default) ---
ENABLE_GMAIL_HOOKS=false
# When false, skip Gmail watcher (OpenClaw gateway). If ENABLE_GMAIL_HOOKS=true, set this to 0 (deploy runs scripts/align-gmail-watcher-env.sh if it is still 1 or unset).
OPENCLAW_SKIP_GMAIL_WATCHER=1

# --- Optional: Google Workspace skills (Gmail send/read, Calendar, Drive) ---
# This template does not install skills or OAuth clients. Use ClawHub + native OpenClaw skill flows
# (see https://documentation.openclaw.ai/clawhub), then enable Calendar/Drive APIs on GOOGLE_CLOUD_PROJECT — docs/GCP_SETUP.md.
# Store OAuth refresh tokens / app passwords only via OpenClaw auth or GSM — never commit.

# --- Optional: host healthcheck after deploy (retry /healthz while gateway boots) ---
# HEALTHCHECK_MAX_WAIT_SECONDS=300
# HEALTHCHECK_INTERVAL_SECONDS=5

# --- OpenTelemetry (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=openclaw-gateway
