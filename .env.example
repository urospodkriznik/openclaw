# Copy to .env and adjust. Never commit .env.
# See docs/DEPLOYMENT.md and docs/GCP_SETUP.md.

# --- OpenClaw image (prebuilt; do not build on e2-micro) ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Persisted OpenClaw home (config, auth profiles) and agent workspace (host paths)
OPENCLAW_CONFIG_DIR=./.openclaw-config
OPENCLAW_WORKSPACE_DIR=./workspace

# Gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=UTC

# Optional: generated on first bootstrap if empty
# OPENCLAW_GATEWAY_TOKEN=$(openssl rand -hex 24)

# Optional: raise on hosts with more RAM (e2-micro default in compose is 768m)
# OPENCLAW_MEMORY_LIMIT=1536m

# Runtime secret strategy
# - Local dev: keep USE_GSM_SECRETS=false and set local tokens in .env
# - GCP prod: set USE_GSM_SECRETS=true and fetch runtime secrets via Secret Manager + IAM
USE_GSM_SECRETS=false
GSM_PROJECT_ID=
GSM_TELEGRAM_BOT_TOKEN_SECRET=openclaw-telegram-bot-token
GSM_OPENAI_API_KEY_SECRET=openclaw-openai-api-key

# --- Vertex AI (google-vertex provider, ADC) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Model id as used by Vertex (no provider prefix here)
VERTEX_MODEL=gemini-2.0-flash-001

# For GCP production, prefer VM attached service account (ADC via metadata server)
# and IAM roles/aiplatform.user over local JSON keys.

# --- Telegram (configure channel; token often injected by CI on deploy) ---
TELEGRAM_BOT_TOKEN=

# --- Optional: OpenAI fallback (provider openai) ---
# OPENAI_API_KEY=

# --- Autonomy (see README) ---
SAFE_MODE=true
FULL_AUTONOMY=false
I_ACCEPT_FULL_AUTONOMY_RISK=
DEMO_MODE=false

# --- Optional: enable Gmail Pub/Sub hooks (advanced; off by default) ---
ENABLE_GMAIL_HOOKS=false
# When false, skip Gmail watcher (OpenClaw gateway)
OPENCLAW_SKIP_GMAIL_WATCHER=1

# --- OpenTelemetry (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=openclaw-gateway
