# Copy to .env and adjust. Never commit .env.
# See docs/DEPLOYMENT.md and docs/GCP_SETUP.md.

# --- OpenClaw image (prebuilt; do not build on e2-micro) ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Persisted OpenClaw home (config, auth profiles) and agent workspace (host paths)
OPENCLAW_CONFIG_DIR=./.openclaw-config
OPENCLAW_WORKSPACE_DIR=./workspace
# Skills such as imap-smtp-email read /home/node/.config/imap-smtp-email/.env — host dir is bind-mounted (gitignored).
OPENCLAW_IMAP_SMTP_CONFIG_DIR=./.openclaw-imap-smtp
# Optional: gog / Google Workspace CLI ([gogcli](https://github.com/openclaw/gogcli))
# When OPENCLAW_GOG_HOST_PATH exists on the host, ./scripts/docker-compose.sh adds docker-compose.gog.yml
# so gateway + CLI see /usr/local/bin/gog and share gogcli data at /home/node/.config/gogcli.
# OPENCLAW_GOG_HOST_PATH=/usr/local/bin/gog
# Host directory mounted at /home/node/.config/gogcli — must be UID 1000-readable (see scripts/sync-gog-cli-config.sh).
# Default ./.openclaw-gog-config; do NOT point at ~/.config/gogcli unless you fix ACLs or chown for the container user.
# OPENCLAW_GOGCLI_CONFIG_DIR=./.openclaw-gog-config
# File keyring on servers (same values you used for `gog auth add` on the host):
# GOG_KEYRING_BACKEND=file
# GOG_KEYRING_PASSWORD=
# Optional default account for gog subcommands:
# GOG_ACCOUNT=you@gmail.com

# Gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_DISABLE_BONJOUR=1
OPENCLAW_TZ=UTC

# Optional: generated on first bootstrap if empty
# OPENCLAW_GATEWAY_TOKEN=$(openssl rand -hex 24)

# Optional: raise on hosts with more RAM (e2-micro default in compose is 768m)
# OPENCLAW_MEMORY_LIMIT=1536m

# Runtime secret strategy
# - Local dev: keep USE_GSM_SECRETS=false and set local tokens in .env
# - GCP prod: set USE_GSM_SECRETS=true and fetch runtime secrets via Secret Manager + IAM
USE_GSM_SECRETS=false
GSM_PROJECT_ID=
GSM_TELEGRAM_BOT_TOKEN_SECRET=openclaw-telegram-bot-token
GSM_OPENAI_API_KEY_SECRET=openclaw-openai-api-key
# Optional: Gemini developer API (provider google); uncomment when the GSM secret exists
# GSM_GEMINI_API_KEY_SECRET=openclaw-gemini-api-key

# --- GCP project (Secret Manager, optional Vertex, metadata) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Gemini developer API (provider google; default in bootstrap-config.sh) ---
# Create a key in Google AI Studio; or use GSM_GEMINI_API_KEY_SECRET + fetch-secrets-gsm.sh
GEMINI_MODEL=gemini-3-flash-preview
# Optional: merge timeout / idle keys into openclaw.json by hand (bootstrap does NOT write them — see config/openclaw-timeouts.example.json5).
# GEMINI_API_KEY=   # paste key from Google AI Studio (or use GSM + fetch-secrets-gsm.sh)

# --- Optional: Vertex AI (google-vertex + ADC) if your OpenClaw image loads that plugin ---
# VERTEX_MODEL=gemini-2.0-flash-001
# For Vertex-only setups, set agents.defaults.model.primary to google-vertex/<VERTEX_MODEL> manually.

# --- Telegram (configure channel; token often injected by CI on deploy) ---
TELEGRAM_BOT_TOKEN=

# --- Optional: OpenAI fallback (provider openai) ---
# OPENAI_API_KEY=

# --- Autonomy (see README) ---
SAFE_MODE=true
FULL_AUTONOMY=false
I_ACCEPT_FULL_AUTONOMY_RISK=
# Headless GCP VM (Telegram only, no Control UI): default SAFE exec asks time out. Set both to relax gateway exec only:
TRUSTED_HEADLESS_EXEC=false
I_ACCEPT_HEADLESS_EXEC_RISK=
DEMO_MODE=false

# --- Optional: enable Gmail Pub/Sub hooks (advanced; off by default) ---
ENABLE_GMAIL_HOOKS=false
# When false, skip Gmail watcher (OpenClaw gateway). If ENABLE_GMAIL_HOOKS=true, set this to 0 (deploy runs scripts/align-gmail-watcher-env.sh if it is still 1 or unset).
OPENCLAW_SKIP_GMAIL_WATCHER=1

# --- Optional: Google Workspace skills (Gmail send/read, Calendar, Drive) ---
# This template does not install skills or OAuth clients. Use ClawHub + native OpenClaw skill flows
# (see https://documentation.openclaw.ai/clawhub), then enable Calendar/Drive APIs on GOOGLE_CLOUD_PROJECT — docs/GCP_SETUP.md.
# Store OAuth refresh tokens / app passwords only via OpenClaw auth or GSM — never commit.

# --- Optional: host healthcheck after deploy (retry /healthz while gateway boots) ---
# HEALTHCHECK_MAX_WAIT_SECONDS=300
# HEALTHCHECK_INTERVAL_SECONDS=5

# --- OpenTelemetry (optional) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
# OTEL_SERVICE_NAME=openclaw-gateway
